USERNAME=write
PASSWORD=write
URL=http://localhost:8888/

MODEL=gpt-4o-mini
API_KEY=???
GENERATION_ENGINE=chatgpt

# MCP server / embedded OAuth2 authorization server (news-backend)
# Externally reachable base URL; advertised as the OAuth issuer + resource server.
MCP_ISSUER_URI=http://localhost:8080
# Browser-based MCP client origins allowed through CORS (comma-separated; * for any).
MCP_CORS_ALLOWED_ORIGINS=*
# Persistent RSA signing key (base64 DER or PEM). Leave unset for an ephemeral dev key
# (tokens are invalidated on every restart). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out key.pem
#   MCP_JWK_PRIVATE_KEY=$(openssl pkcs8 -topk8 -nocrypt -in key.pem | sed '1d;$d' | tr -d '\n')
#   MCP_JWK_PUBLIC_KEY=$(openssl rsa -in key.pem -pubout | sed '1d;$d' | tr -d '\n')
MCP_JWK_PRIVATE_KEY=
MCP_JWK_PUBLIC_KEY=
