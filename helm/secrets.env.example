# Plain-text secrets for deep-digest-rss
# Copy this file to secrets.env and fill in real values.
# Then run: ./helm/seal-secrets.sh
#
# WARNING: Never commit secrets.env to git!

SPRING_DATASOURCE_USERNAME=news-app
SPRING_DATASOURCE_PASSWORD=
AUTH_ACTUATOR_PASSWORD=
AUTH_SWAGGER_PASSWORD=
AUTH_WRITE_PASSWORD=
SCRAPER_API_KEY=
API_KEY=
ANTHROPIC_API_KEY=
DISCORD_WEBHOOK_URLS=

# Stable RSA keypair for signing MCP OAuth2 access tokens. Without these the
# backend generates an ephemeral key on each restart, invalidating all issued
# tokens (forces every MCP client to re-authenticate after a redeploy).
# Generate single-line base64 DER values with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwk.pem
#   MCP_JWK_PRIVATE_KEY=$(openssl pkey -in jwk.pem -outform DER | openssl base64 -A)
#   MCP_JWK_PUBLIC_KEY=$(openssl pkey -in jwk.pem -pubout -outform DER | openssl base64 -A)
MCP_JWK_PRIVATE_KEY=
MCP_JWK_PUBLIC_KEY=
